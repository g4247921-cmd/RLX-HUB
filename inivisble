local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- CONFIGURATION
local CONFIG = {
    TOGGLE_KEY = Enum.KeyCode.X,
    UI_COLORS = {
        BG = Color3.fromRGB(12, 12, 12),
        ACCENT = Color3.fromRGB(40, 40, 40),
        ON = Color3.fromRGB(39, 174, 96),
        OFF = Color3.fromRGB(192, 57, 43),
        TEXT = Color3.fromRGB(255, 255, 255)
    }
}

-- UI CREATION
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "AnjaszRelaxz_UI"

local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 220, 0, 180)
main.Position = UDim2.new(0.5, -110, 0.5, -90)
main.BackgroundColor3 = CONFIG.UI_COLORS.BG
main.Active = true
main.Draggable = true
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)

-- Animated Gradient Border (Moving Effect)
local stroke = Instance.new("UIStroke", main)
stroke.Thickness = 2
stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

local grad = Instance.new("UIGradient", stroke)
grad.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 255)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 0, 255)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 255, 255))
})

-- Animate Gradient
task.spawn(function()
    while true do
        TweenService:Create(grad, TweenInfo.new(3, Enum.EasingStyle.Linear), {Offset = Vector2.new(1, 1)}):Play()
        task.wait(3)
        grad.Offset = Vector2.new(-1, -1)
    end
end)

-- TITLE & CREDIT
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1, 0, 0, 40)
title.Text = "INVISIBILITY TOOL"
title.TextColor3 = CONFIG.UI_COLORS.TEXT
title.Font = Enum.Font.GothamBold
title.TextSize = 16
title.BackgroundTransparency = 1

local credit = Instance.new("TextLabel", main)
credit.Size = UDim2.new(1, 0, 0, 20)
credit.Position = UDim2.new(0, 0, 0, 30)
credit.Text = "By AnjaszRelaxz"
