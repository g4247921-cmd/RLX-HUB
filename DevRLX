-- Engine Penghitung FPS & Ping Otomatis
local fpsCount = 0
local lastFpsUpdate = os.clock()

RunService.RenderStepped:Connect(function()
	fpsCount = fpsCount + 1
	local now = os.clock()
	if now - lastFpsUpdate >= 1 then
		local currentFps = math.floor(fpsCount / (now - lastFpsUpdate))
		
		-- Mengambil data ping murni dari Network Performance Stats
		local currentPing = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
		
		StatsLabel.Text = "⚡ <b>FPS:</b> " .. currentFps .. " | 📡 <b>PING:</b> " .. currentPing .. " ms"
		
		-- Reset counter
		fpsCount = 0
		lastFpsUpdate = now
	end
end)

