-- BUTTON
local toggleBtn = Instance.new("TextButton", main)
toggleBtn.Size = UDim2.new(0, 180, 0, 50)
toggleBtn.Position = UDim2.new(0.5, -90, 0, 70)
toggleBtn.BackgroundColor3 = CONFIG.UI_COLORS.OFF
toggleBtn.Text = "STATUS: OFF"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 8)

-- LOGIC
local isInvisible = false
local function setTransparency(v)
    for _, obj in pairs(player.Character:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Decal") then
            if obj.Name ~= "HumanoidRootPart" then obj.Transparency = v end
        end
    end
end

toggleBtn.MouseButton1Click:Connect(function()
    isInvisible = not isInvisible
    if isInvisible then
        local seat = Instance.new("Seat", workspace)
        seat.Name = "RLX_Invis_Seat"
        seat.Transparency = 1
        seat.CFrame = player.Character.HumanoidRootPart.CFrame
        seat:Sit(player.Character.Humanoid)
        
        toggleBtn.BackgroundColor3 = CONFIG.UI_COLORS.ON
        toggleBtn.Text = "STATUS: ON"
        setTransparency(1)
    else
        local seat = workspace:FindFirstChild("RLX_Invis_Seat")
        if seat then seat:Destroy() end
        
        toggleBtn.BackgroundColor3 = CONFIG.UI_COLORS.OFF
        toggleBtn.Text = "STATUS: OFF"
        setTransparency(0)
    end
end)

game:GetService("UserInputService").InputBegan:Connect(function(inp, gp)
    if not gp and inp.KeyCode == CONFIG.TOGGLE_KEY then
        toggleBtn:MouseButton1Click()
    end
end)

