-- Safe Loader Core
local function safeLoad(url)
	task.spawn(function()
		local ok, res = pcall(function() return game:HttpGet(url) end)
		if ok then 
			local fn = loadstring(res) 
			if fn then fn() end 
		else
			warn("[RLX Error]: Gagal memuat script dari source external.")
		end
	end)
end

